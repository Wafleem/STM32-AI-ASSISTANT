{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stm32-ai-agent-staging",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-30",
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "stm32-pins-db-staging",
      "database_id": "e5b8d6a0-4213-4f2d-b3bf-32532c57bb37"
    }
  ],
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "stm32-knowledge"
    }
  ]
}
